{
	"name": "blank-ui",
	"version": "0.0.1",
	"description": "Unstyled, accessible UI components.",
	"module": "./dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./modal": "./dist/components/modal.js",
		"./scss": "./src/scss/style.scss"
	},
	"files": [
		"dist",
		"src/scss"
	],
	"scripts": {
		"build:js": "vite build",
		"build:cdn": "vite build --mode cdn && vite build --mode cdn-min",
		"build:css": "sass src/scss/style.scss dist/blank-ui.css --style=expanded --no-source-map && sass src/scss/style.scss dist/blank-ui.min.css --style=compressed --no-source-map",
		"build": "npm run build:js && npm run build:cdn && npm run build:css",
		"dev": "vite",
		"preview": "vite preview",
		"prepare": "husky",
		"format": "prettier --write .",
		"lint:ts": "eslint \"src/ts/**/*.ts\" --no-error-on-unmatched-pattern",
		"lint:style": "stylelint \"src/**/*.scss\" --allow-empty-input",
		"lint:style:fix": "stylelint \"src/**/*.scss\" --fix --allow-empty-input",
		"lint-staged": "lint-staged",
		"tsx": "tsx",
		"tsx:watch": "tsx watch",
		"playground:init": "cp playground/index.sample.html playground/index.html"
	},
	"lint-staged": {
		"*.{ts,json,scss,md}": [
			"prettier --write"
		],
		"*.ts": [
			"eslint"
		],
		"*.scss": [
			"stylelint --fix"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/twyn-dev/blank-ui.git"
	},
	"keywords": [
		"ui components",
		"accessible components",
		"headless components"
	],
	"author": "Tony Nguyen",
	"license": "MIT",
	"type": "module",
	"bugs": {
		"url": "https://github.com/twyn-dev/blank-ui/issues"
	},
	"homepage": "https://github.com/twyn-dev/blank-ui#readme",
	"engines": {
		"node": ">=24"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"prettier": "3.8.3",
		"sass": "^1.99.0",
		"stylelint": "^17.11.1",
		"stylelint-config-standard-scss": "^17.0.0",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13"
	}
}
