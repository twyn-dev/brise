{
	"printWidth": 80,
	"tabWidth": 4,
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"semi": true,
	"endOfLine": "lf",
	"bracketSpacing": true,
	"arrowParens": "always",
	"bracketSameLine": true,
	"overrides": [
		{
			"files": ["*.html"],
			"options": {
				"tabWidth": 2
			}
		},
		{
			"files": ["*.md"],
			"options": {
				"tabWidth": 2,
				"proseWrap": "always"
			}
		}
	]
}
